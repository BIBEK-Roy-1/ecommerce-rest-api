{
  "openapi": "3.0.3",
  "info": {
    "version": "1.0.0",
    "title": "E-commerce REST API",
    "description": "REST API for an E-commerce application built using Node.js, Express.js and JWT authentication."
  },
 "servers": [
  {
    "url": "/",
    "description": "Current server"
  }
],
  "tags": [
    {
      "name": "General",
      "description": "General API routes"
    },
    {
      "name": "Users",
      "description": "User signup and signin APIs"
    },
    {
      "name": "Products",
      "description": "Product CRUD, filtering and rating APIs"
    },
    {
      "name": "Cart",
      "description": "Shopping cart APIs"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "API welcome route",
        "description": "Checks whether the API server is running.",
        "responses": {
          "200": {
            "description": "API server is running"
          }
        }
      }
    },
    "/api/user/signup": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Create a new user",
        "description": "Registers a new customer or seller.",
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Invalid user details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "New user details",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserSignupRequest"
              }
            }
          }
        }
      }
    },
    "/api/user/signin": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Sign in user",
        "description": "Authenticates a user and returns a JWT token.",
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SigninResponse"
                }
              }
            }
          },
          "400": {
            "description": "Incorrect credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "User login credentials",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserSigninRequest"
              }
            }
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Get all products",
        "description": "Returns all products available in the application.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Products fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Products"
        ],
        "summary": "Add a new product",
        "description": "Creates and adds a new product.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "201": {
            "description": "Product added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Product added successfully"
                    },
                    "product": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid product details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "Product details",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        }
      }
    },
    "/api/products/filter": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Filter products",
        "description": "Filters products using minimum price, maximum price and category.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered products returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "minPrice",
            "in": "query",
            "description": "Minimum product price",
            "required": false,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "description": "Maximum product price",
            "required": false,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Product category",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/products/rate": {
      "post": {
        "tags": [
          "Products"
        ],
        "summary": "Rate a product",
        "description": "Adds or updates the authenticated user's rating for a product.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Rating added or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Rating added successfully"
                    },
                    "product": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Rating must be between 1 and 5",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "User or product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "Product ID and rating",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RatingInput"
              }
            }
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Get one product",
        "description": "Returns a product using its ID.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Product found successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Product ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ]
      },
      "put": {
        "tags": [
          "Products"
        ],
        "summary": "Update a product",
        "description": "Updates one or more fields of an existing product.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Product updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Product updated successfully"
                    },
                    "product": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid product details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Product ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "description": "Fields to update",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductUpdateInput"
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Products"
        ],
        "summary": "Delete a product",
        "description": "Removes a product using its ID.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Product deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Product deleted successfully"
                    },
                    "product": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Product ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ]
      }
    },
    "/api/cartItems": {
      "get": {
        "tags": [
          "Cart"
        ],
        "summary": "Get authenticated user's cart",
        "description": "Returns all cart items belonging to the authenticated user.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Cart items fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CartItem"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Cart"
        ],
        "summary": "Add product to cart",
        "description": "Adds a product to the authenticated user's cart.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "201": {
            "description": "Product added to cart successfully"
          },
          "400": {
            "description": "Invalid product ID or quantity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "productId",
            "in": "query",
            "description": "ID of the product to add",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "quantity",
            "in": "query",
            "description": "Quantity of the product",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ]
      }
    },
    "/api/cartItems/{id}": {
      "delete": {
        "tags": [
          "Cart"
        ],
        "summary": "Remove item from cart",
        "description": "Removes a cart item belonging to the authenticated user.",
        "security": [
          {
            "JWT": []
          }
        ],
        "responses": {
          "200": {
            "description": "Cart item removed successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Cart item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Cart item ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "JWT": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "Paste only your JWT token"
      }
    },
    "schemas": {
      "UserSignupRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "password",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Bibek Roy"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "bibek@gmail.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "1234"
          },
          "type": {
            "type": "string",
            "enum": [
              "customer",
              "seller"
            ],
            "example": "customer"
          }
        }
      },
      "UserSigninRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "bibek@gmail.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "1234"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Bibek Roy"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "bibek@gmail.com"
          },
          "type": {
            "type": "string",
            "example": "customer"
          }
        }
      },
      "SigninResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Login successful"
          },
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": [
          "name",
          "desc",
          "category",
          "price",
          "size"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Adidas Running Shoes"
          },
          "desc": {
            "type": "string",
            "example": "Lightweight and comfortable running shoes."
          },
          "imageUrl": {
            "type": "string",
            "example": "/uploads/adidas-shoes.jpg"
          },
          "category": {
            "type": "string",
            "example": "Category1"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 4999
          },
          "size": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "7",
              "8",
              "9",
              "10"
            ]
          }
        }
      },
      "ProductUpdateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Updated Product Name"
          },
          "desc": {
            "type": "string",
            "example": "Updated product description."
          },
          "imageUrl": {
            "type": "string",
            "example": "/uploads/updated-product.jpg"
          },
          "category": {
            "type": "string",
            "example": "Category2"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 5499
          },
          "size": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "M",
              "L",
              "XL"
            ]
          }
        }
      },
      "Rating": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "example": 1
          },
          "rating": {
            "type": "number",
            "format": "float",
            "minimum": 1,
            "maximum": 5,
            "example": 5
          }
        }
      },
      "RatingInput": {
        "type": "object",
        "required": [
          "productId",
          "rating"
        ],
        "properties": {
          "productId": {
            "type": "integer",
            "example": 1
          },
          "rating": {
            "type": "number",
            "format": "float",
            "minimum": 1,
            "maximum": 5,
            "example": 5
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Nike Air Max"
          },
          "desc": {
            "type": "string",
            "example": "Comfortable running shoes with breathable mesh."
          },
          "imageUrl": {
            "type": "string",
            "example": "/uploads/nike-airmax.jpg"
          },
          "category": {
            "type": "string",
            "example": "Category1"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 5999
          },
          "size": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "7",
              "8",
              "9",
              "10"
            ]
          },
          "rating": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Rating"
            }
          }
        }
      },
      "CartItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "productId": {
            "type": "integer",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "example": 2
          },
          "quantity": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Something went wrong"
          },
          "error": {
            "type": "string",
            "example": "Error details"
          }
        }
      }
    }
  }
}